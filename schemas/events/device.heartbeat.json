{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "device.heartbeat",
  "type": "object",
  "required": ["type", "eventId", "createdAt", "deviceId", "battery", "wifiRssi", "screen"],
  "properties": {
    "type": { "const": "device.heartbeat" },
    "eventId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "deviceId": { "type": "string", "minLength": 1 },
    "battery": { "type": "integer", "minimum": 0, "maximum": 100 },
    "wifiRssi": { "type": "integer", "minimum": -100, "maximum": 0 },
    "screen": { "type": "string", "minLength": 1 }
  }
}
