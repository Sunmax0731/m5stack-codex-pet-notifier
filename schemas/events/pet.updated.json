{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pet.updated",
  "type": "object",
  "required": ["type", "eventId", "createdAt", "pet"],
  "properties": {
    "type": { "const": "pet.updated" },
    "eventId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "pet": {
      "type": "object",
      "required": ["id", "name", "state", "spriteRef"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "state": {
          "type": "string",
          "enum": ["idle", "waiting", "running", "failed", "review", "reacting", "celebrate"]
        },
        "spriteRef": { "type": "string", "minLength": 1 },
        "fallbackState": { "type": "string" }
      }
    }
  }
}
