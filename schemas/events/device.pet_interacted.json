{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "device.pet_interacted",
  "type": "object",
  "required": ["type", "eventId", "createdAt", "deviceId", "petId", "interaction"],
  "properties": {
    "type": { "const": "device.pet_interacted" },
    "eventId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "deviceId": { "type": "string", "minLength": 1 },
    "petId": { "type": "string", "minLength": 1 },
    "interaction": {
      "type": "string",
      "enum": [
        "touch",
        "tap",
        "double-tap",
        "long-press",
        "button-long-press",
        "swipe-up",
        "swipe-down",
        "swipe-left",
        "swipe-right"
      ]
    },
    "gesture": {
      "type": "string",
      "enum": [
        "touch",
        "single-tap",
        "double-tap",
        "long-press",
        "button-long-press",
        "swipe-up",
        "swipe-down",
        "swipe-left",
        "swipe-right"
      ]
    },
    "target": {
      "type": "string",
      "enum": ["screen", "pet", "footer", "answer", "choice", "button"]
    },
    "screen": { "type": "string", "minLength": 1 },
    "page": { "type": "integer", "minimum": 0 },
    "mood": {
      "type": "string",
      "enum": ["idle", "listening", "thinking", "happy", "surprised", "confused", "sleepy", "worried", "alert", "proud"]
    }
  }
}
